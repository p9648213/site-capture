generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Site {
  id         Int        @id @default(autoincrement())
  name       String
  siteId     String
  status     String     @default("INCOMPLETE")
  updatedAt  DateTime   @updatedAt
  categories Category[]

  @@index([status])
}

model Category {
  id           Int           @id @default(autoincrement())
  siteId       Int
  name         String
  status       String        @default("INCOMPLETE")
  updatedAt    DateTime      @updatedAt
  site         Site          @relation(fields: [siteId], references: [id], onDelete: Cascade)
  pictureTypes PictureType[]

  @@index([siteId])
  @@index([status])
}

model PictureType {
  id          Int      @id @default(autoincrement())
  categoryId  Int
  name        String
  isFulfilled Boolean  @default(false)
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  photos      Photo[]

  @@index([categoryId])
  @@index([categoryId, sortOrder])
}

model Photo {
  id             Int         @id @default(autoincrement())
  pictureTypeId  Int
  localUri       String?
  serverFilePath String
  latitude       Float?
  longitude      Float?
  capturedAt     DateTime
  pictureType    PictureType @relation(fields: [pictureTypeId], references: [id], onDelete: Cascade)

  @@index([pictureTypeId])
}
